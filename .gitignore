# Paper Ecology — hosting .gitignore
# Goal: host ALL active work toward MannyAI + the 240+C8+W8 papers, but exclude
# heavy binaries, runtime DBs, caches, staging, and secrets.

# ---- Runtime / precached databases (referenced by path, not versioned) ----
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm

# ---- Heavy literature / derivation PDFs (manifest-tracked instead) ----
*.pdf
PaperLib/**/*.pdf
**/ARXIV_PDFS/**/*.pdf
ProofLib/**/*.pdf

# ---- Python caches / build ----
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.benchmarks/

# ---- OS / editor ----
.DS_Store
Thumbs.db
.vscode/
.cursor/

# ---- Secrets (NEVER tracked) ----
.env
*.env
*.key
*.pem
*secret*
credentials*

# ---- Transient / staging (already demoted locally, double-guard) ----
_reorg_staging/
_tmp/
_zip_local/
.zip_staging/
.cqe/
.local-git-sources/
.local-git-remotes/

# ---- Local demotion archive (Q6: history, not hosted) ----
_LOCAL_DEMOTED/

# ---- Hermes session artifacts ----
.hermes/
