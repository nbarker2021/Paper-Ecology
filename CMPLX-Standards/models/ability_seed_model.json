{
  "schema": "cmplx_standards_model.v1",
  "model_id": "cmplx.ability_seed",
  "version": "0.1.0",
  "description": "Grades LOCAL and LEGACY ability seeds for MannyAI/TMN unification port readiness.",
  "record_selector": "seeds",
  "record_id_paths": [
    "seed_id",
    "record_id",
    "id"
  ],
  "thresholds": {
    "perfect_fit": 1.0,
    "model_inclusive": 0.88,
    "partial_inclusive": 0.6,
    "weak_inclusive": 0.3
  },
  "allowed_value_penalty": 0.2,
  "allowed_values": {
    "seed_type": [
      "local_ability_seed",
      "legacy_repo_ability_seed"
    ],
    "port_mode": [
      "direct_port",
      "minor_rewrite",
      "rebuild_better"
    ],
    "pairing_status": [
      "candidate_local_ability",
      "candidate_legacy_ability"
    ]
  },
  "weighted_fields": {
    "seed_id": 3,
    "seed_type": 2,
    "title": 2,
    "ability_family": 3,
    "source_surface": 2,
    "source_path": 3,
    "source_paths": 3,
    "proposed_flcr_targets": 4,
    "pipeline_targets": 3,
    "port_mode": 3,
    "port_rationale": 2,
    "confidence": 2,
    "blockers": 2,
    "pairing_status": 2,
    "provenance_label": 2,
    "cmplx_standards_gate": 3,
    "forge_reforge_action": 2,
    "rationale": 2
  },
  "conditional_required_fields": {
    "port_mode": {
      "direct_port": [
        {
          "path": "source_paths",
          "weight": 3
        },
        {
          "path": "pipeline_targets",
          "weight": 2
        }
      ],
      "minor_rewrite": [
        {
          "path": "blockers",
          "weight": 2
        },
        {
          "path": "port_rationale",
          "weight": 2
        }
      ],
      "rebuild_better": [
        {
          "path": "blockers",
          "weight": 3
        },
        {
          "path": "rationale",
          "weight": 3
        }
      ]
    }
  }
}
