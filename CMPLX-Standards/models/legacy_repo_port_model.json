{
  "schema": "cmplx_standards_model.v1",
  "model_id": "cmplx.legacy_repo_port",
  "version": "0.2.0",
  "description": "Grades legacy repo ports into CMPLX-Standards. Executable and contract-bound records can close; broad candidate_indexed intake records are intentionally scored below concrete ports until promoted.",
  "record_selector": "records",
  "record_id_paths": [
    "port_id",
    "source_seed",
    "record_id"
  ],
  "thresholds": {
    "perfect_fit": 1.0,
    "model_inclusive": 0.9,
    "partial_inclusive": 0.65,
    "weak_inclusive": 0.35
  },
  "allowed_value_penalty": 0.25,
  "allowed_values": {
    "port_status": [
      "ported",
      "contract_bound"
    ],
    "validation_status": [
      "pass"
    ],
    "provenance_label": [
      "legacy_repo_port_adapter"
    ]
  },
  "weighted_fields": {
    "port_id": 4,
    "source_seed": 4,
    "ability_family": 3,
    "source_paths": 4,
    "destination": 4,
    "port_status": 5,
    "validation_status": 5,
    "validation_summary": 4,
    "honesty_boundary": 5,
    "blockers": 2,
    "provenance_label": 2
  },
  "conditional_required_fields": {
    "port_status": {
      "ported": [
        {
          "path": "validation_summary.checks",
          "weight": 4
        },
        {
          "path": "validation_summary.stats",
          "weight": 3
        }
      ],
      "contract_bound": [
        {
          "path": "validation_summary.field_checks",
          "weight": 4
        },
        {
          "path": "validation_summary.term_checks",
          "weight": 4
        }
      ],
      "candidate_indexed": [
        {
          "path": "validation_summary.candidate_checks",
          "weight": 4
        },
        {
          "path": "validation_summary.path_stats",
          "weight": 4
        },
        {
          "path": "validation_summary.syntax_probe",
          "weight": 4
        },
        {
          "path": "validation_summary.promotion_readiness",
          "weight": 4
        }
      ]
    }
  }
}
