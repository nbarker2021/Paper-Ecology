{
  "schema": "cmplx_standards_model.v1",
  "model_id": "cmplx.assembly_cluster",
  "version": "0.1.0",
  "description": "Groups triads and octads as composite assemblies of ability_seed records. Captures higher-level cluster metadata without requiring individual seed fields.",
  "record_selector": "assemblies",
  "record_id_paths": [
    "assembly_id"
  ],
  "thresholds": {
    "perfect_fit": 1.0,
    "model_inclusive": 0.90,
    "partial_inclusive": 0.6,
    "weak_inclusive": 0.3
  },
  "allowed_value_penalty": 0.2,
  "allowed_values": {
    "assembly_type": [
      "triad",
      "octad"
    ],
    "promotion_status": [
      "candidate_assembly_only",
      "promoted",
      "declined"
    ]
  },
  "weighted_fields": {
    "assembly_id": 3,
    "title": 2,
    "assembly_type": 3,
    "seed_count": 2,
    "seed_ids": 3,
    "ability_families": 2,
    "source_repos": 2,
    "proposed_flcr_targets": 2,
    "claim_window": 2,
    "review_question": 2,
    "mean_confidence": 2,
    "blockers": 1,
    "promotion_status": 2,
    "cmplx_standards_gate": 2,
    "forge_reforge_action": 2
  }
}
