{
  "schema": "cmplx_standards_model.v1",
  "model_id": "cmplx.code_supplement",
  "version": "0.1.0",
  "description": "Captures machine-level code supplements, analog workbooks, and verifier artifacts from the code-indexing agent. References ability_seed and legacy_repo_port models.",
  "record_selector": "supplements",
  "record_id_paths": [
    "supplement_id",
    "record_id"
  ],
  "thresholds": {
    "perfect_fit": 1.0,
    "model_inclusive": 0.9,
    "partial_inclusive": 0.6,
    "weak_inclusive": 0.3
  },
  "allowed_value_penalty": 0.15,
  "allowed_values": {
    "supplement_type": [
      "machine_verifier",
      "analog_workbook",
      "code_supplement",
      "receipt_index",
      "obligation_ledger"
    ],
    "language": [
      "Python",
      "C",
      "C++",
      "Markdown",
      "JSON",
      "YAML",
      "Shell",
      "Docker",
      "TypeScript",
      "JavaScript"
    ],
    "status": [
      "active",
      "deprecated",
      "pending_review",
      "verified"
    ]
  },
  "weighted_fields": {
    "supplement_id": 3,
    "title": 2,
    "supplement_type": 3,
    "language": 2,
    "file_count": 2,
    "size_bytes": 1,
    "status": 2,
    "target_papers": 3,
    "source_repo": 2,
    "verifier_count": 2,
    "receipt_count": 2,
    "has_tests": 2,
    "has_documentation": 2
  }
}