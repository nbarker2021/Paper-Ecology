{
  "schema": "cmplx_standards_model.v1",
  "model_id": "cmplx.application_validation",
  "version": "0.1.0",
  "description": "General CMPLX application validation model built from paper validators, receipt evidence, runtime commands, and standards models.",
  "record_selector": "records",
  "record_id_paths": [
    "application_id",
    "record_id",
    "id"
  ],
  "thresholds": {
    "perfect_fit": 1.0,
    "model_inclusive": 0.9,
    "partial_inclusive": 0.65,
    "weak_inclusive": 0.35
  },
  "allowed_value_penalty": 0.25,
  "allowed_values": {
    "status": [
      "pass"
    ],
    "source_path_exists": [
      "yes"
    ],
    "standards_model_exists": [
      "yes"
    ],
    "provenance_label": [
      "application_validator_adapter"
    ]
  },
  "weighted_fields": {
    "application_id": 4,
    "application_type": 3,
    "source_path": 4,
    "source_path_exists": 5,
    "tests_command": 4,
    "runtime_command": 4,
    "standards_model": 4,
    "standards_model_exists": 5,
    "validator_links": 5,
    "paper_validation_tool_count": 4,
    "paper_validation_families": 3,
    "receipt_count": 3,
    "receipt_paths": 2,
    "status": 5,
    "blockers": 2,
    "provenance_label": 2
  },
  "conditional_required_fields": {
    "application_type": {
      "validator": [
        {
          "path": "standards_model",
          "weight": 4
        },
        {
          "path": "validator_links",
          "weight": 4
        }
      ],
      "runtime_substrate": [
        {
          "path": "runtime_command",
          "weight": 4
        },
        {
          "path": "receipt_paths",
          "weight": 3
        }
      ],
      "cam_base": [
        {
          "path": "validator_links",
          "weight": 4
        },
        {
          "path": "tests_command",
          "weight": 4
        }
      ],
      "product_runtime": [
        {
          "path": "validator_links",
          "weight": 4
        },
        {
          "path": "receipt_paths",
          "weight": 3
        }
      ]
    }
  }
}
