{
  "schema": "cmplx_standards_model.v1",
  "model_id": "cmplx.maximal_manuscript",
  "version": "0.1.0",
  "description": "Grades maximal reader-facing FLCR manuscripts for required sections and audit linkage.",
  "record_selector": "records",
  "record_id_paths": [
    "paper_id",
    "record_id",
    "id"
  ],
  "thresholds": {
    "perfect_fit": 1.0,
    "model_inclusive": 0.9,
    "partial_inclusive": 0.65,
    "weak_inclusive": 0.35
  },
  "allowed_value_penalty": 0.15,
  "allowed_values": {
    "prose_tier": [
      "maximal_publication",
      "maximal_publication_with_calibration_footnote",
      "none"
    ]
  },
  "weighted_fields": {
    "paper_id": 3,
    "title": 2,
    "prose_tier": 2,
    "has_abstract": 4,
    "has_main_results": 5,
    "has_construction": 4,
    "has_downstream_program": 3,
    "has_active_channels": 3,
    "has_methods_note": 2,
    "has_evidence_appendix": 4,
    "has_assembled_link": 3,
    "claim_count": 2,
    "receipt_count": 2
  },
  "conditional_required_fields": {
    "prose_tier": {
      "maximal_publication": [
        {
          "path": "has_main_results",
          "weight": 4
        },
        {
          "path": "has_evidence_appendix",
          "weight": 3
        }
      ],
      "maximal_publication_with_calibration_footnote": [
        {
          "path": "has_main_results",
          "weight": 4
        },
        {
          "path": "calibration_footnote",
          "weight": 3
        }
      ]
    }
  }
}
