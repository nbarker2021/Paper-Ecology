{
  "schema": "cmplx_standards_model.v1",
  "model_id": "cmplx.assembled_paper",
  "version": "0.1.0",
  "description": "Grades paper_assembly_intake 15-section assembled products for model-fit before standards-gated refresh.",
  "record_selector": "records",
  "record_id_paths": [
    "paper_id",
    "record_id",
    "id"
  ],
  "thresholds": {
    "perfect_fit": 1.0,
    "model_inclusive": 0.9,
    "partial_inclusive": 0.65,
    "weak_inclusive": 0.35
  },
  "allowed_value_penalty": 0.15,
  "allowed_values": {
    "status": [
      "ASSEMBLE",
      "ASSEMBLE_PENDING_NEW_TEST",
      "DISCOVERY",
      "REVIEW",
      "REROUTE",
      "UNKNOWN"
    ],
    "pipeline_decision": [
      "ASSEMBLE",
      "DEFER",
      "PEEP_HOLD",
      "DISCOVERY",
      "REROUTE",
      ""
    ]
  },
  "weighted_fields": {
    "paper_id": 3,
    "title": 2,
    "status": 2,
    "pipeline_decision": 2,
    "formal_md": 2,
    "formal_sections.abstract": 4,
    "formal_sections.keywords": 2,
    "formal_sections.claims": 5,
    "required_direct.open_obligations": 3,
    "required_direct.paired_dois": 2,
    "required_direct.peep_bindings": 2,
    "required_direct.assembly_audit_falsifier_gaps": 2,
    "supporting_context.timeline_node_count": 1,
    "supporting_context.registry_discovery_count": 1,
    "external_candidates.seed_count": 2,
    "external_candidates.ingress_count": 2,
    "receipts": 4,
    "closure_inclusions": 3,
    "meta.intake_version": 1,
    "meta.epistemology": 2,
    "assembled_section_count": 3,
    "has_proof_receipt_index": 2,
    "has_obligation_crosswalk": 2,
    "has_external_calibration": 2,
    "has_falsifiers_section": 2,
    "has_honesty_boundary": 2
  },
  "conditional_required_fields": {
    "status": {
      "ASSEMBLE": [
        {
          "path": "receipts",
          "weight": 3
        },
        {
          "path": "formal_sections.claims",
          "weight": 3
        }
      ],
      "DISCOVERY": [
        {
          "path": "blockers",
          "weight": 2
        }
      ]
    }
  }
}
